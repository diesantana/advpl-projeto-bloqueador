#include "totvs.ch"

/*/{Protheus.doc} zBloque
Bloqueia o cadastro de um cliente.
@type function
@author Diego Santana
@since 12/05/2026
/*/
User Function zBloque()
	Local oDialog
	Local oLabelCl // Label Cliente
	Local oLabelLj // Label Loja
	Local oButton // Bot„o para bloquear cliente

	// TGET Cliente
	Local oInputCl // Tget Cliente (INPUT)
	Local cClient := Space(6) // Armazena o valor do TGet Cliente

	// TGET Loja
	Local oInputLj // Tget Loja (INPUT)
	Local cLoja := Space(2)  // Armazena o valor do TGet Loja

	// Cria TDialog
	oDialog := TDialog():New(0,0,300,500,'Bloquear Clientes',,,,,CLR_BLACK,CLR_WHITE,,,.T.)

	// Campo Cliente + label
	oLabelCl:= TSay():New(10,10,{||'Cliente'},oDialog,,,,,,.T.,CLR_RED,CLR_WHITE,300,20)
	oInputCl := TGet():New( 20,10,{|u| if( Pcount( )>0,cClient:= u, cClient) },oDialog,40,10,"@!",,0,,,.F.,,.T.,,.F.,,.F.,.F.,,.F.,.F.,,cClient,,,, )
	oInputCl:cF3 := "SA1" // Consulta padr„o SA1 Clientes

	// Campo Loja + label
	oLabelLj:= TSay():New(10,60,{||'Loja'},oDialog,,,,,,.T.,CLR_RED,CLR_WHITE,300,20)
	oInputLj := TGet():New( 20,60,{|u| if( Pcount( )>0,cLoja:= u, cLoja) },oDialog,30,10,"@!",,0,,,.F.,,.T.,,.F.,,.F.,.F.,,.F.,.F.,,cLoja,,,, )

	// Cria o bot„o "Bloquar cliente"
	oButton := TButton():New( 60, 10, "Bloquear Cliente",oDialog,{|| fBloquear(cClient, cLoja)}, 60,15,,,.F.,.T.,.F.,,.F.,,,.F. )


	oDialog:Activate(,,,.T.) // Ativa a tela

Return

/*/{Protheus.doc} fBloquear
    Bloqueia o cliente atravÈs do campo A1_MSBLQL. 
    @type Function
    @param cCode, Character, CÛdigo do cliente a ser bloqueado
    @param cLoja, Character, CÛdigo da Loja
    @author Diego Santana
    @since 12/05/2026
/*/
Static Function fBloquear(cCode, cLoja)

	// Boa pr·tica, salva o contexto da ·rea de trabalho atual
	Local cArea := GetArea()

	// Abre a tabela SA1 em uma area de trabalho
	DbSelectArea("SA1")
	// Define o INDICE padr„o para buscas
	SA1->(DbSetOrder(1)) // Filial + CÛdigo

	//Busca o cliente usando o Ìndice 1 (FILIAL+C”D+LOJA)
	SA1->(DbSeek(xFilial("SA1")+cCode+cLoja))

	RecLock("SA1", .F.) // .F. = ediÁ„o
	SA1->A1_MSBLQL := '1' 
	MsUnlock()

	// Informa ao usu·rio que o registro foi atualizado
	MsgInfo("O cliente <strong>"+  AllTrim(SA1->A1_NOME) +"</strong> foi bloqueado com sucesso.", "Cliente Bloquado") 

	// Boa pr·tica, restaura o contexto da ·rea de trabalho anterior
	RestArea(cArea)
Return
